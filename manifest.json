{
  "manifest_version": 3,
  "name": "DolphinMind Browser Assistant",
  "version": "1.2.0",
  "description": "DolphinMind 智能浏览器助手",
  "permissions": [
    "debugger",
    "tabs",
    "tabGroups",
    "scripting",
    "sidePanel",
    "alarms",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "DolphinMind 控制台"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "injector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  }
}