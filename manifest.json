{
  "manifest_version": 3,
  "name": "AI Agent Debugger Host (Pro)",
  "version": "1.1.0",
  "description": "全功能 CDP 控制中心",
  "permissions": [
    "debugger",
    "tabs",
    "scripting",
    "sidePanel",
    "activeTab"
  ],
  "action": {
    "default_title": "AI Agent 控制台"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:*/*",
        "http://localhost:*/*",
        "file:///*"
      ],
      "js": [
        "injector.js"
      ],
      "run_at": "document_end"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  }
}